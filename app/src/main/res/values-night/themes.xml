<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Linkup_android" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/color_primary</item>

        <item name="colorControlNormal">@color/white</item>
        <item name="android:statusBarColor">@color/color_F9F9F9</item>
        <item name="android:navigationBarColor">@color/color_F9F9F9</item>
        <!-- Customize your theme here. -->
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="snackbarStyle">@style/Snackbar.Margin.0dp</item>
    </style>

    <style name="Snackbar.Margin.0dp" parent="@style/Widget.MaterialComponents.Snackbar">
        <item name="android:layout_margin">0dp</item>
    </style>

    <style name="progressbar_color">
        <item name="colorAccent">@color/color_primary</item>
    </style>


    <style name="Toolbar.TitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">15dp</item>
        <item name="android:textColor">@color/color_666666</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>
</resources>