<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TEXT_MAIN" parent="Widget.AppCompat.TextView">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">sans-serif-light</item>
    </style>

    <style name="TEXT_TITLE" parent="TEXT_MAIN">
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TEXT_CONTENT" parent="TEXT_MAIN">
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/shadow</item>
        <item name="android:scrollbars">vertical</item>
    </style>

    <style name="TEXT_CONTENT_CENTER" parent="TEXT_MAIN">
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="EDIT_TEXT_MAIN" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/selector_edit_text</item>
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">sans-serif-light</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
    </style>

    <style name="BUTTON_MAIN" parent="Widget.AppCompat.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="fontFamily">sans-serif-light</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="BUTTON_MAIN_SELECTOR" parent="BUTTON_MAIN">
        <item name="android:background">@drawable/bt_red_rounded</item>
        <item name="android:textColor">@drawable/selector_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CUSTOM_RADIO_BUTTON_MAIN" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:button">@null</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="fontFamily">sans-serif-light</item>
    </style>

    <style name="CARD_MAIN" parent="CardView">
        <item name="paddingStart">8dp</item>
        <item name="paddingEnd">8dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:background">@drawable/bg_item_selector</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="android:gravity">center</item>
        <item name="cardElevation">2dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardCornerRadius">8dp</item>
    </style>

    <style name="CHECK_BOX_MAIN" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:button">@null</item>
        <item name="android:drawableEnd">?android:attr/listChoiceIndicatorMultiple</item>
        <item name="fontFamily">sans-serif-light</item>
        <item name="android:textStyle">normal</item>
    </style>


</resources>